# URL completa da API (com /api/v1).
# Em `next dev`, se não definir nada, o admin usa http://127.0.0.1:3000/api/v1 (Nest local).
# Para apontar para a VPS no dev: descomente abaixo ou crie .env.local.
# NEXT_PUBLIC_API_URL=http://72.61.35.190:3000/api/v1

# Dev local: API Nest na 3000 + Postgres com seed (admin@ondeacho.app / Admin@123).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/api/v1

# Legado (opcional): mesmo efeito se NEXT_PUBLIC_API_URL não estiver definido.
# NEXT_PUBLIC_API_BASE_URL=http://72.61.35.190:3000/api/v1

# Desligar logs de URL no console (padrão: ligado). Defina 0 para silenciar.
# NEXT_PUBLIC_API_LOG_REQUESTS=0
