# Origens permitidas (separadas por vírgula). Inclua site público, admin, localhost e IPs locais em dev.
# Produção (exemplo): https://ondeachotea.com,https://www.ondeachotea.com,https://admin.ondeachotea.com
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3001,http://127.0.0.1:3002
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
