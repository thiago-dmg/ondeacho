{
  "name": "backend",
  "version": "1.0.0",
  "description": "API do OndeAcho",
  "main": "dist/main.js",
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-db-assets.cjs",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "db:migrate": "node dist/database/migrate.js",
    "db:migrate:dev": "ts-node src/database/migrate.ts",
    "db:seed": "node dist/database/seed.js",
    "db:seed:dev": "ts-node src/database/seed.ts",
    "db:import-clinicas": "ts-node src/database/import-clinicas-json.ts",
    "test": "echo \"Configurar testes na etapa seguinte\""
  },
  "keywords": [],
  "author": "OndeAcho",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^4.21.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^20.17.30",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
