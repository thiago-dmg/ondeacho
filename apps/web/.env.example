# URL completa da API (com /api/v1). Produção na VPS:
NEXT_PUBLIC_API_URL=https://api.ondeachotea.com/api/v1

# URL pública do site (metadados / links absolutos opcionais)
NEXT_PUBLIC_SITE_URL=https://ondeachotea.com

# Desligar logs de URL no console (padrão: ligado). Defina 0 para silenciar.
# NEXT_PUBLIC_API_LOG_REQUESTS=0
